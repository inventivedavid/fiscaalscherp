# ─────────────────────────────────────────────────────────────────
# Publieke basisconfiguratie
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://fiscaalscherp.nl
NEXT_PUBLIC_BRAND_NAME=Fiscaalscherp
NEXT_PUBLIC_CONTACT_EMAIL=hallo@fiscaalscherp.nl
NEXT_PUBLIC_CAL_URL=https://cal.com/fiscaalscherp/30min
NEXT_PUBLIC_KVK_NUMBER=

# Optioneel: Plausible analytics (privacyvriendelijk, geen cookies)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─────────────────────────────────────────────────────────────────
# Baserow (database)
#   Maak in Baserow een database "Fiscaalscherp" met tabellen zoals beschreven in README.md
#   Genereer een Database Token met CRUD-rechten op die database.
# ─────────────────────────────────────────────────────────────────
BASEROW_API_URL=https://api.baserow.io
BASEROW_TOKEN=your_baserow_database_token_here
BASEROW_SCANS_TABLE_ID=123456
BASEROW_FINDINGS_TABLE_ID=123457
BASEROW_EVENTS_TABLE_ID=123458

# ─────────────────────────────────────────────────────────────────
# Resend (email delivery)
#   https://resend.com — verifieer jouwdomein.nl + stel DKIM/SPF in.
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM="Fiscaalscherp <rapport@fiscaalscherp.nl>"
EMAIL_REPLY_TO=hallo@fiscaalscherp.nl

# ─────────────────────────────────────────────────────────────────
# Vercel Cron security — random string, ingesteld als "Authorization: Bearer ..."
# ─────────────────────────────────────────────────────────────────
CRON_SECRET=change_me_random_string

# ─────────────────────────────────────────────────────────────────
# Dossier hervat-tokens — HMAC-secret voor de magic-links die het
# vertrouwelijke dossier op een ander apparaat hervatten.
# Genereer met: `openssl rand -base64 32`
# Valt terug op CRON_SECRET als hij niet is gezet (ok voor dev,
# zet 'm vast voor productie zodat je 'm onafhankelijk kunt roteren).
# ─────────────────────────────────────────────────────────────────
DOSSIER_SECRET=change_me_strong_random_string

# ─────────────────────────────────────────────────────────────────
# Admin-panel (basic auth) — /admin
# ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_random_string
